# HailHunter — Environment Variables
# Copy this file to .env and fill in your keys before running locally.
# On Streamlit Cloud: add these under Settings → Secrets instead.

# ── NOAA CDO API Token ────────────────────────────────────────────────────────
# Get your free token at: https://www.ncdc.noaa.gov/cdo-web/token
# Just enter your email — token arrives instantly. No payment required.
#
# Phase 2: wired in but not consumed — storm data comes from NCEI CSV files
#          which are public and require no authentication.
# Phase 3: used for station-level climate queries, zone statistics, and
#          building-permit-derived roof-age enrichment via CDO API v2.
NOAA_TOKEN=

# ── OpenWeather API Key ───────────────────────────────────────────────────────
# Get your free key at: https://openweathermap.org/api → "Get API key"
# Free tier: 1,000 calls/day, 60 calls/minute.
#
# Phase 2: reverse geocode lat/lon → city name when NOAA field is empty.
# Phase 3: current conditions surfaced in the zone intelligence panel.
# Optional — the app runs fully without this key; geocoding is skipped.
OPENWEATHER_API_KEY=
